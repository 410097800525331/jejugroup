<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xmlns="http://xmlns.jcp.org/xml/ns/javaee"
         xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee http://xmlns.jcp.org/xml/ns/javaee/web-app_4_0.xsd"
         id="WebApp_ID" version="4.0"
         metadata-complete="true">
  <display-name>jeju-web</display-name>

  <filter>
    <filter-name>CorsFilter</filter-name>
    <filter-class>util.CorsFilter</filter-class>
  </filter>
  <filter-mapping>
    <filter-name>CorsFilter</filter-name>
    <url-pattern>/*</url-pattern>
  </filter-mapping>

  <servlet>
    <servlet-name>SignupServlet</servlet-name>
    <servlet-class>controller.SignupServlet</servlet-class>
  </servlet>
  <servlet>
    <servlet-name>LoginServlet</servlet-name>
    <servlet-class>controller.LoginServlet</servlet-class>
  </servlet>
  <servlet>
    <servlet-name>VerifyController</servlet-name>
    <servlet-class>controller.VerifyController</servlet-class>
  </servlet>
  <servlet>
    <servlet-name>PublicConfigServlet</servlet-name>
    <servlet-class>controller.PublicConfigServlet</servlet-class>
  </servlet>
  <servlet>
    <servlet-name>InquiryListServlet</servlet-name>
    <servlet-class>controller.InquiryListServlet</servlet-class>
  </servlet>
  <servlet>
    <servlet-name>InquiryWriteServlet</servlet-name>
    <servlet-class>controller.InquiryWriteServlet</servlet-class>
  </servlet>
  <servlet>
    <servlet-name>InquiryInsertServlet</servlet-name>
    <servlet-class>controller.InquiryInsertServlet</servlet-class>
  </servlet>
  <servlet>
    <servlet-name>InquiryDetailServlet</servlet-name>
    <servlet-class>controller.InquiryDetailServlet</servlet-class>
  </servlet>
  <servlet>
    <servlet-name>InquiryApiServlet</servlet-name>
    <servlet-class>controller.InquiryApiServlet</servlet-class>
  </servlet>

  <servlet-mapping>
    <servlet-name>SignupServlet</servlet-name>
    <url-pattern>/api/auth/signup</url-pattern>
  </servlet-mapping>
  <servlet-mapping>
    <servlet-name>LoginServlet</servlet-name>
    <url-pattern>/api/auth/login</url-pattern>
  </servlet-mapping>
  <servlet-mapping>
    <servlet-name>VerifyController</servlet-name>
    <url-pattern>/api/auth/verify</url-pattern>
  </servlet-mapping>
  <servlet-mapping>
    <servlet-name>PublicConfigServlet</servlet-name>
    <url-pattern>/api/public/config</url-pattern>
  </servlet-mapping>
  <servlet-mapping>
    <servlet-name>InquiryListServlet</servlet-name>
    <url-pattern>/inquiry/list</url-pattern>
  </servlet-mapping>
  <servlet-mapping>
    <servlet-name>InquiryWriteServlet</servlet-name>
    <url-pattern>/inquiry/write</url-pattern>
  </servlet-mapping>
  <servlet-mapping>
    <servlet-name>InquiryInsertServlet</servlet-name>
    <url-pattern>/inquiry/insert</url-pattern>
  </servlet-mapping>
  <servlet-mapping>
    <servlet-name>InquiryDetailServlet</servlet-name>
    <url-pattern>/inquiry/detail</url-pattern>
  </servlet-mapping>
  <servlet-mapping>
    <servlet-name>InquiryApiServlet</servlet-name>
    <url-pattern>/api/inquiries</url-pattern>
  </servlet-mapping>

  <welcome-file-list>
    <welcome-file>index.jsp</welcome-file>
    <welcome-file>index.html</welcome-file>
  </welcome-file-list>
</web-app>
