{
  "private": true,
  "workspaces": [
    "front/apps/cs"
  ],
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "dev:cs": "npm run dev -w front/apps/cs",
    "check:cs": "npm run check -w front/apps/cs",
    "build:cs": "npm run build -w front/apps/cs",
    "guard:text": "node scripts/guards/check-text-integrity.js --all",
    "guard:text:staged": "node scripts/guards/check-text-integrity.js --staged",
    "guard:mirror:staged": "node scripts/guards/check-webapp-mirror.js --staged",
    "setup:hooks": "node scripts/guards/install-hooks.js",
    "smoke:cs": "pnpm dlx @playwright/test test scripts/smoke/cs-customer-center.smoke.spec.cjs --reporter=list",
    "smoke:front": "pnpm dlx @playwright/test test scripts/smoke/front-entrypoints.smoke.spec.cjs --reporter=list",
    "sync": "node scripts/pipelines/sync-front.js",
    "build": "npm run build:cs && npm run sync && node scripts/pipelines/build-war.js",
    "deploy": "npm run build && node scripts/pipelines/deploy.js",
    "publish": "npm run deploy"
  },
  "dependencies": {
    "dotenv": "^17.3.1",
    "mysql2": "^3.18.0",
    "node-ssh": "^13.2.1",
    "ssh2": "^1.17.0"
  },
  "devDependencies": {
    "@faker-js/faker": "^10.3.0",
    "bcryptjs": "^3.0.3",
    "fs-extra": "^11.3.4"
  }
}
