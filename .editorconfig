root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
indent_style = space
indent_size = 2
trim_trailing_whitespace = true

[*.md]
trim_trailing_whitespace = false

[*.{html,css,js,cjs,mjs,ts,tsx,jsx,json,yml,yaml,xml,txt,java,properties}]
charset = utf-8
end_of_line = lf

[scripts/guards/**.{js,cjs,mjs}]
charset = utf-8-bom

[scripts/pipelines/**.{js,cjs,mjs}]
charset = utf-8-bom

[scripts/utils/**.{js,cjs,mjs}]
charset = utf-8-bom

[docs/text-integrity-guardrails.md]
charset = utf-8-bom

[docs/transition-architecture.md]
charset = utf-8-bom
